<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude everything: the DataStore holds the PIN hash and the database holds
     usage history; neither should leave the device (allowBackup is also false). -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="root" path="." />
</full-backup-content>
