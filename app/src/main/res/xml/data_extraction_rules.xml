<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude everything from cloud backup and device-to-device transfer:
     the DataStore holds the PIN hash and the database holds usage history. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
