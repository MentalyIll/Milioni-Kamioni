    <!-- Accessibility Service -->
    <string name="accessibility_service_label">StayFree Screen Monitor</string>
    <string name="accessibility_service_description">StayFree uses the Accessibility Service to detect which app or website is currently open so it can enforce your blocking rules.</string>

    <!-- Onboarding -->
    <string name="onboarding_usage_title">Usage Access</string>
    <string name="onboarding_usage_desc">StayFree needs permission to view your app usage statistics. This lets us show you exactly how much time you spend in each app.</string>
    <string name="onboarding_accessibility_title">Accessibility Service</string>
    <string name="onboarding_accessibility_desc">Enable StayFree in Accessibility Settings to allow it to detect your active app and enforce blocking rules.</string>
    <string name="onboarding_overlay_title">Display Over Other Apps</string>
    <string name="onboarding_overlay_desc">StayFree needs to draw over other apps to show the block screen when you try to open a blocked app.</string>
    <string name="onboarding_notifications_title">Notifications</string>
    <string name="onboarding_notifications_desc">Allow notifications so StayFree can alert you when you are approaching your daily limits.</string>
    <string name="onboarding_battery_title">Battery Optimization</string>
    <string name="onboarding_battery_desc">Exclude StayFree from battery optimization so it keeps tracking even when your screen is off.</string>

