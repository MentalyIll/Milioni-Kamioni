<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-screen interstitial shown AFTER the host app (YouTube/Instagram) is
    sent to the background. Pure black for now ("crna slika"); the ad_container
    is the slot a real AdMob Interstitial template plugs into later.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/interstitial_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fitsSystemWindows="true">

    <!-- AdMob Interstitial template slot. The real interstitial is shown by the
         AdMob SDK over the whole activity; this container holds the placeholder
         (and any future native/banner fallback). -->
    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tv_ad_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/interstitial_placeholder"
            android:textColor="#33FFFFFF"
            android:textSize="14sp"
            android:letterSpacing="0.15"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Small dismiss affordance so the user is never trapped on the black
         screen (mirrors the close button on a real interstitial). -->
    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/interstitial_close"
        app:tint="#66FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</FrameLayout>
