<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8C000000"
    android:padding="@dimen/spacing_lg">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/spacing_xl">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="@dimen/spacing_md"
                android:src="@drawable/ic_illust_moon"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tv_overlay_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/tv_overlay_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/on_surface_variant"
                android:textAlignment="center"
                android:text="@string/content_block_subtitle"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_overlay_back"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/content_block_back"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_overlay_bypass"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/content_block_need_more"
                android:layout_marginTop="@dimen/spacing_xs"
                android:visibility="gone" />

            <!-- PIN entry (revealed when bypass is tapped) -->
            <LinearLayout
                android:id="@+id/pin_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_overlay_pin"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/pin_enter_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_overlay_pin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberPassword"
                        android:maxLength="8" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_overlay_pin_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_confirm"
                    app:cornerRadius="28dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
